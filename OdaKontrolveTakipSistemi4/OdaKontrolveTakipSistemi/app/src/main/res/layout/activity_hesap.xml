<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".HesapActivity">

    <EditText
        android:id="@+id/mail_txtbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ems="10"
        android:hint="Lütfen mailinizi giriniz..."
        android:inputType="text"
        tools:layout_editor_absoluteX="110dp"
        tools:layout_editor_absoluteY="391dp" />

    <EditText
        android:id="@+id/sifre_txtbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ems="10"
        android:hint="Lütfen şifrenizi giriniz..."
        android:inputType="textPassword"
        tools:layout_editor_absoluteX="110dp"
        tools:layout_editor_absoluteY="444dp" />

    <EditText
        android:id="@+id/sifre_tekrar_txtbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ems="10"
        android:hint="Tekrar şifrenizi giriniz..."
        android:inputType="textPassword"
        tools:layout_editor_absoluteX="110dp"
        tools:layout_editor_absoluteY="499dp" />

    <Button
        android:id="@+id/button4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:onClick="hesap_olustur"
        android:text="Hesap Oluştur"
        tools:layout_editor_absoluteX="139dp"
        tools:layout_editor_absoluteY="587dp" />

    <EditText
        android:id="@+id/editTextText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ems="10"
        android:hint="TC'nizi Giriniz..."
        android:inputType="text"
        tools:layout_editor_absoluteX="110dp"
        tools:layout_editor_absoluteY="45dp" />

    <EditText
        android:id="@+id/editTextText2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ems="10"
        android:hint="Adınızı Giriniz..."
        android:inputType="text"
        tools:layout_editor_absoluteX="110dp"
        tools:layout_editor_absoluteY="100dp" />

    <EditText
        android:id="@+id/editTextText3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ems="10"
        android:hint="Soyadınızı Giriniz..."
        android:inputType="text"
        tools:layout_editor_absoluteX="110dp"
        tools:layout_editor_absoluteY="158dp" />

</androidx.constraintlayout.widget.ConstraintLayout>