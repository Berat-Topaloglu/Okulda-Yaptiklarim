<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".HesapActivity">

    <EditText
        android:id="@+id/mail_txtbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="2dp"
        android:layout_marginBottom="30dp"
        android:ems="10"
        android:hint="Lütfen mailinizi giriniz..."
        android:inputType="text"
        app:layout_constraintBottom_toTopOf="@+id/sifre_txtbox"
        app:layout_constraintEnd_toEndOf="@+id/sifre_txtbox" />

    <EditText
        android:id="@+id/sifre_txtbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="190dp"
        android:layout_marginEnd="90dp"
        android:ems="10"
        android:hint="Lütfen şifrenizi giriniz..."
        android:inputType="textPassword"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/sifre_tekrar_txtbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:ems="10"
        android:hint="Tekrar şifrenizi giriniz..."
        android:inputType="textPassword"
        app:layout_constraintStart_toStartOf="@+id/sifre_txtbox"
        app:layout_constraintTop_toBottomOf="@+id/sifre_txtbox" />

    <Button
        android:id="@+id/button4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="36dp"
        android:layout_marginTop="54dp"
        android:onClick="hesap_olustur"
        android:text="Hesap Oluştur"
        app:layout_constraintStart_toStartOf="@+id/sifre_tekrar_txtbox"
        app:layout_constraintTop_toBottomOf="@+id/sifre_tekrar_txtbox" />
</androidx.constraintlayout.widget.ConstraintLayout>