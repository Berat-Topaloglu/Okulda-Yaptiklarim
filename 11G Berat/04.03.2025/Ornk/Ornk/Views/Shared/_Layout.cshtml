<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ornk</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" integrity="sha384-tViUnnbYAV00FLIhhi3v/dWt3Jxw4gZQcNoSCxCIFNJVCx7/D55/wXsrNIRANwdD" crossorigin="anonymous">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Ornk.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-black border-bottom box-shadow">
            <div class="container-fluid">
                <a class="navbar-brand fs-1 text-light" style="font-family:'Monotype Corsiva'" asp-area="" asp-controller="Menü" asp-action="Index2">Tuzla Meslek</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex">
                    <ul class="navbar-nav flex-grow-1 justify-content-center">
                        <li class="nav-item">
                            <a class="nav-link text-warning active" asp-area="" asp-controller="Menü" asp-action="Index2">AnaSayfa</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-controller="Menü" asp-action="Index">Ürün Listele</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-controller="Menü" asp-action="Create">Ürün Ekle</a>
                        </li>
                    </ul>
                </div>
                <div class="text-light">
                    <i class="bi bi-person-fill" style="padding:0px 10px;"></i>
                    <i class="bi bi-cart-fill" style="padding-right:10px;"></i>
                    <i class="bi bi-search" style="padding-right:10px;"></i>
                    <button type="button" class="btn btn-warning text-light">Online Sipariş</button>
                </div>
            </div>
        </nav>
    </header>
    <div style="height:700px;background-image:url('images/hero-bg.jpg');background-size:cover; padding-top:65px;">
        <div class="w-50 p-5">
            <div class="card-body text-light">
                <h2 class="fs-1" style="font-family:'Monotype Corsiva'">Fast Food Resturant</h2>
                <p class="card-text">Lorem Ipsum is simply dummy text of the printing and typesetting industry. Lorem Ipsum has been the industry's standard dummy text ever since the 1500s, when an unknown printer took a galley of type and scrambled it to make a type specimen book. </p>
                <a href="#" class="btn btn-warning text-light">Order Now</a>
            </div>
        </div>
    </div>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <form>
        <p class="text-black text-center fs-3" style="font-family:'Monotype Corsiva'">Book a Table</p>
        <!-- 2 column grid layout with text inputs for the first and last names -->
        <div class="w-50 m-auto mb-3">
            <div>
                <div data-mdb-input-init class="form-outline">
                    <input type="text" id="form3Example1" class="form-control" />
                    <label class="form-label" for="form3Example1">Your name</label>
                </div>
            </div>
        </div>

        <div data-mdb-input-init class="form-outline w-50 m-auto mb-3">
            <input type="number" id="form6Example6" class="form-control" />
            <label class="form-label" for="form6Example6">Phone Number</label>
        </div>
        <!-- Email input -->
        <div data-mdb-input-init class="form-outline w-50 m-auto mb-3">
            <input type="email" id="form3Example3" class="form-control" />
            <label class="form-label" for="form3Example3">Email address</label>
        </div>
        <input type="date" id="inputPassword5" class="form-control m-auto w-50 mb-3" aria-describedby="passwordHelpBlock">
        <select class="form-select m-auto w-50 mb-3" aria-label="Default select example">
            <option selected>How many Person?</option>
            <option value="1">One</option>
            <option value="2">Two</option>
            <option value="3">Three</option>
        </select>
        <!-- Submit button -->
        <button data-mdb-ripple-init type="button" class="btn btn-primary" style="margin-left:45%;">Sign up</button>
    </form>
    <p class="text-black text-center fs-3" style="font-family:'Monotype Corsiva'">What Says Our Custemors</p>
    <div class="container">
        <div class="row">
            <div class="col">
                <div class="bg-black text-light">
                    <div class="card-body">
                        <h5 class="card-title">Mike Hammell</h5>
                        <p class="card-text">With supporting text below as a natural lead-in to additional content.</p>
                        <span>Lorem Ipsum</span>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="bg-black text-light">
                    <div class="card-body">
                        <h5 class="card-title">Antony Stephan</h5>
                        <p class="card-text">With supporting text below as a natural lead-in to additional content.</p>
                        <span>Lorem Ipsum</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <footer class="bg-black text-center text-lg-start mt-3">
        <!-- Grid container -->
        <div class="container p-4 text-light">
            <!--Grid row-->
            <div class="row">
                <!--Grid column-->
                <div class="col">
                    <h5 class="text-uppercase" style="font-family:'Monotype Corsiva'">Contact Us</h5>

                    <ul class="list-unstyled mb-0">
                        <li>
                            <i class="bi bi-geo-alt-fill"> Location</i>
                        </li>
                        <li>
                            <i class="bi bi-telephone-fill"> Call +123 4567 8910</i>
                        </li>
                        <li>
                            <i class="bi bi-envelope-fill"> ghostanonim@gmail.com</i>
                        </li>
                    </ul>
                </div>
                <!--Grid column-->
                <!--Grid column-->
                <div class="col">
                    <div class="card-title text-center text-light">
                        Lorem Ipsum is simply dummy text of the printing and typesetting industry. Lorem Ipsum has been the industry's standard dummy text ever since the 1500s, when an unknown printer took a galley of type and scrambled it to make a type specimen book.
                    </div>
                    <div class="text-light text-center pt-2">
                        <i class="bi bi-facebook p-3"></i>
                        <i class="bi bi-twitter p-3"></i>
                        <i class="bi bi-linkedin p-3"></i>
                        <i class="bi bi-instagram p-3"></i>
                        <i class="bi bi-pinterest p-3"></i>
                    </div>
                </div>
                <!--Grid column-->
                <!--Grid column-->
                <div class="col">
                    <h5 class="text-uppercase mb-0 text-center" style="font-family:'Monotype Corsiva'">Opening House</h5>
                    <p class="text-center text-light">Everday</p>
                    <p class="text-center text-light">10:00 AM - 10:00 PM</p>
                </div>
                <!--Grid column-->
            </div>
            <!--Grid row-->
        </div>
        <!-- Grid container -->
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
