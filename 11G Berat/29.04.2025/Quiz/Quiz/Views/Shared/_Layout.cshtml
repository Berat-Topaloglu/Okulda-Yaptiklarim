<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quiz</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" integrity="sha384-tViUnnbYAV00FLIhhi3v/dWt3Jxw4gZQcNoSCxCIFNJVCx7/D55/wXsrNIRANwdD" crossorigin="anonymous">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-SgOJa3DmI69IUzQ2PVdRZhwQ+dy64/BUtbMJw1MZ8t5HZApcHrRKUc4W0kG879m7" crossorigin="anonymous">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Quiz.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-dark box-shadow mb-3">
            <div class="container-fluid">
                <div class="navbar-collapse collapse d-sm-inline-flex mx-5 pt-2 pb-2">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-controller="Blogs" asp-action="Index2">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light">Blog Posts</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light">About</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-action="Index" asp-controller="Blogs">Category</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light">Post Format</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light">Contact</a>
                        </li>
                    </ul>
                </div>
                <div class="me-4 text-white">
                    <i class="bi bi-facebook px-1"></i>
                    <i class="bi bi-twitter px-1"></i>
                    <i class="bi bi-linkedin px-1"></i>
                    <i class="bi bi-pinterest"></i>
                </div>
            </div>
        </nav>
        <div class="container">
            <h2 style="margin-left:35%;"><i>TUZLA MESLEK</i></h2>
            <div class="row mt-3">

                <div class="col-lg-8 mx-3">
                    <img src="~/img/bg-fashion.jpg" width="750" height="400"/>
                </div>

                <div class="col-lg-3">
                    <div class="text-center">
                        <div class="bg-image hover-overlay ripple" data-mdb-ripple-color="light">
                            <img src="~/img/author.jpg" class="rounded-circle" width="135" height="135" />
                        </div>

                        <div class="card-body">
                            <h5 class="card-title">Liam Mason</h5>
                            <p class="text-secondary mb-1">Travel Blogger</p>
                            <p class="card-text text-secondary">
                                Lorem Ipsum is simply dummy text of the printing and typesetting industry. Lorem Ipsum has been the industry's standard dummy text ever since the 1500s.
                            </p>
                            <h3 class="mt-1 mb-1"><i>LİAM MASON</i></h3>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <div class="container">
        <div class="row">
            <div class="col-lg-4 col-md-12">
                <div class="card" style="width: 18rem;">
                    <img src="~/img/img-4.jpg" class="card-img-top" alt="..." height="290">
                    <div class="fs-6" style="color:orange;">
                        TRAVEL
                    </div>
                    <div class="card-body">
                        <h5 class="card-title">Trip Of California</h5>
                        <p class="card-text">Some quick example text to build on the card title and make up the bulk of the card's content.</p>
                       
                    </div>
                </div>
            </div>

            <div class="col-lg-4 col-md-6">
                <div class="card" style="width: 18rem;">
                    <img src="~/img/f1.jpg" class="card-img-top" alt="...">
                    <div class="fs-6" style="color:orange;">
                        EXPLORE
                    </div>
                    <div class="card-body">
                        <h5 class="card-title">Ways To Reach Goals</h5>
                        <p class="card-text">Some quick example text to build on the card title and make up the bulk of the card's content.</p>
                        
                    </div>
                </div>
            </div>

            <div class="col-lg-4 col-md-6">
                <div class="card" style="width: 18rem;">
                    <img src="~/img/f3.jpg" class="card-img-top" alt="...">
                    <div class="fs-6" style="color:orange;">
                        TRAVEL
                    </div>
                    <div class="card-body">
                        <h5 class="card-title">Feel Like Home</h5>
                        <p class="card-text">Some quick example text to build on the card title and make up the bulk of the card's content.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <footer class="bg-black text-center text-lg-start text-white">
        <!-- Copyright -->
        <div class="text-center p-3 text-light">
            © 2020 Copyright:
            <a class="text-white text-decoration-none" href="#">Tuzla Mesleki ve Teknik Anadolu Lisesi</a>
        </div>
        <!-- Copyright -->
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/js/bootstrap.bundle.min.js" integrity="sha384-k6d4wzSIapyDyv1kpU366/PK5hCdSbCRGRCMv+eplOQJWyd1fbcAu9OCUj5zNLiq" crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
